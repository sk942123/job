<script>
function filter(cat, btn){
  document.querySelectorAll('.filters button').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.card').forEach(c=>{
    if(cat==='all'){c.classList.remove('hidden');return;}
    c.dataset.cat&&c.dataset.cat.includes(cat)?c.classList.remove('hidden'):c.classList.add('hidden');
  });
  // show/hide section headers based on visible cards
  ['high','medium','stretch'].forEach(s=>{
    const sec=document.getElementById('sec-'+s);
    if(!sec)return;
    const visible=[...sec.querySelectorAll('.card')].some(c=>!c.classList.contains('hidden'));
    sec.style.display=visible?'':'none';
  });
}
</script>
</body>
</html>
